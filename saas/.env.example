# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Google OAuth ───────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# Redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft / Azure AD OAuth (Outlook — Family+ tier) ───────
# Register an app at https://portal.azure.com/ → App registrations
# Required API permissions (delegated): Calendars.Read, offline_access, User.Read
# Redirect URI (Web): https://yourdomain.com/api/auth/microsoft/callback
# Tenant: 'common' for multi-tenant accounts (personal + work). Set
# to a specific tenant GUID if you want to restrict to your org only.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# ── Supabase ───────────────────────────────────────────────────
# From Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Token Encryption ───────────────────────────────────────────
# AES-256 key for encrypting OAuth tokens at rest
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Stripe Price IDs ───────────────────────────────────────────
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_FAMILY_PLUS_MONTHLY=
STRIPE_PRICE_FAMILY_PLUS_YEARLY=

# ── Upstash Redis (rate limiting) ──────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend (transactional email) ───────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── OpenWeatherMap ─────────────────────────────────────────────
# Free tier at openweathermap.org — 1,000 calls/day is plenty
OPENWEATHER_API_KEY=

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Cron (weekly email summary) ────────────────────────
# Generate with: openssl rand -hex 16
CRON_SECRET=

# ── Web Push (VAPID) ──────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL that identifies the app owner.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com
